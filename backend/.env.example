PORT=5000
NODE_ENV=development

# MongoDB
MONGO_URI=
MONGO_URI_DIRECT=
MONGO_DNS_FALLBACK=8.8.8.8,1.1.1.1
MONGO_DNS_TIMEOUT_MS=5000
MONGO_SERVER_SELECTION_TIMEOUT_MS=15000
MONGO_CONNECT_TIMEOUT_MS=10000
MONGO_SOCKET_TIMEOUT_MS=45000

# JWT
JWT_SECRET=your_super_secret_jwt_key_here_change_in_production
JWT_EXPIRES_IN=7d

# Cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Frontend URL (for CORS)
CLIENT_URL=http://localhost:5173







# AI Provider (`groq` is default)
AI_PROVIDER=groq
AI_ENABLE_OFFLINE_FALLBACK=true
# Free-tier safety controls
AI_MAX_INPUT_MESSAGES=10
AI_MAX_MESSAGE_CHARS=1200
AI_MAX_CONTEXT_CHARS=1200
AI_MAX_OUTPUT_TOKENS=256
AI_TEMPERATURE=0.4
AI_MIN_REQUEST_INTERVAL_MS=2500
AI_MAX_REQUESTS_PER_MINUTE=12
# Groq (free-tier friendly)
GROQ_API_KEY=your_groq_api_key
GROQ_API_BASE_URL=https://api.groq.com/openai/v1
GROQ_MODEL=llama-3.1-8b-instant
GROQ_FALLBACK_MODELS=llama-3.1-8b-instant,llama3-8b-8192,gemma2-9b-it
# Optional Grok (paid/team credits required)
# GROK_API_BASE_URL=https://api.x.ai/v1
# Optional Gemini
GEMINI_API_KEY=your_google_ai_studio_key
GEMINI_MODEL=gemini-2.0-flash
GEMINI_API_VERSION=v1beta
GEMINI_FALLBACK_MODELS=gemini-2.0-flash,gemini-1.5-flash
GEMINI_FALLBACK_API_VERSIONS=v1beta,v1