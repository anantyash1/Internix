PORT=5000
NODE_ENV=development

# MongoDB
MONGO_URI=mongodb+srv://anantyash902:anantyash902@interncluster.kygykee.mongodb.net/internix?retryWrites=true&w=majority&appName=Interncluster
# Optional non-SRV fallback (Atlas "Standard connection string")
MONGO_URI_DIRECT=mongodb://anantyash902:anantyash902@interncluster.kygykee.mongodb.net/internix?replicaSet=Interncluster&ssl=true&authSource=admin&retryWrites=true&w=majority
MONGO_DNS_FALLBACK=8.8.8.8,1.1.1.1
MONGO_DNS_TIMEOUT_MS=5000
MONGO_SERVER_SELECTION_TIMEOUT_MS=15000
